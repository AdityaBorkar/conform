{
  "author": {
    "email": "hello@adityab.tech",
    "name": "Aditya Borkar",
    "url": "https://adityab.tech"
  },
  "bin": {
    "conform": "src/cli.ts"
  },
  "bugs": "https://github.com/AdityaBorkar/conform/issues",
  "dependencies": {
    "bun": "^1.3.14",
    "commander": "^15.0.0"
  },
  "description": "CLI tool that checks repositories against conformance templates",
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/cli": "^2.31.0",
    "@types/bun": "^1.3.14",
    "husky": "^9.1.7",
    "taze": "^19.14.1",
    "vitest": "^4.1.9"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": ["src", "templates"],
  "homepage": "https://github.com/AdityaBorkar/conform#readme",
  "keywords": ["conform", "check"],
  "license": "MIT",

  "maintainers": [
    {
      "email": "hello@adityab.tech",
      "name": "Aditya Borkar",
      "url": "https://adityab.tech"
    }
  ],
  "module": "src/index.ts",
  "name": "@adityab/conform",
  "peerDependencies": {
    "typescript": "^7.0.1-rc"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AdityaBorkar/conform.git"
  },
  "scripts": {
    "changeset": "changeset",
    "check:lint": "biome check . --fix",
    "check:types": "tsc --noEmit",
    "prepare": "husky",
    "release": "changeset publish",
    "test": "vitest run",
    "test:e2e": "vitest run tests/e2e/",
    "test:integration": "vitest run tests/integration/ --passWithNoTests",
    "test:unit": "vitest run --exclude 'tests/e2e/**'",
    "test:watch": "vitest",
    "update:deps": "taze -w && bun install",
    "version": "changeset version && bun run scripts/ensure-unreleased.ts"
  },
  "sideEffects": false,
  "type": "module",
  "version": "0.1.0"
}
